# Copy to .env and fill in values
PORT=4000
DB_PATH=./data/public_insta.db
IG_APP_ID=your_instagram_app_id
IG_APP_SECRET=your_instagram_app_secret
IG_REDIRECT_URI=http://localhost:4000/auth/callback
# Instagram user access token (or use OAuth flow to obtain)
IG_USER_ACCESS_TOKEN=

# Ollama model to use (must be available in local ollama)
OLLAMA_MODEL=llama2
# Optional: path or command for ollama (default: 'ollama')
OLLAMA_CMD=ollama

# Optional keyword service API keys if you integrate one later
KEYWORD_SERVICE_API_KEY=
